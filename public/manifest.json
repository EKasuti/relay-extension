{
  "name": "Relay",
  "description": "Transfer work shifts between apps and autofill timesheets.",
  "version": "1.2.1",
  "manifest_version": 3,
  "icons": {
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "scripting",
    "sidePanel",
    "storage"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "host_permissions": [
    "https://dartmouth.studentemployment.ngwebsolutions.com/*",
    "https://os.dali.dartmouth.edu/*",
    "http://localhost:3001/*"
  ]
}

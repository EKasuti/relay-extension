{
    "name": "Relay",
    "description": "Transfer work shifts between apps and autofill timesheets.",
    "version": "1.0",
    "manifest_version": 3,
    "icons": {
        "32": "icons/icon32.png",
        "64": "icons/icon64.png"
    },
    "action" : {
        "default_popup": "index.html"
    },
    "permissions" : [ 
        "scripting",
        "sidePanel"
    ],
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "host_permissions": [
        "https://*/*",
        "http://*/*"
    ]
}